<?xml version="1.0" encoding="UTF-8" ?>
<component type="desktop-application">
  <id>io.github.weiteck.Lyricade</id>

  <name>Lyricade</name>
  <summary>Download and manage lyrics for your music library</summary>

  <metadata_license>FSFAP</metadata_license>
  <project_license>Apache-2.0</project_license>

  <content_rating type="oars-1.1" />

  <launchable type="desktop-id">io.github.weiteck.Lyricade.desktop</launchable>

  <description>
    <p>
      Scan your music library and download missing lyrics, in either synchronised LRC
      or plain text format, at your preference. It also assists in managing your
      existing embedded and external lyrics.
    </p>

    <p>
      Features:
    </p>
    <ul>
      <li>Scan your music and find missing lyrics</li>
      <li>Download either synchronous LRC or plain lyrics</li>
      <li>Embed lyrics to the metadata tag, save as a sidecar file, or both</li>
      <li>Embed <em>existing</em> sidecar <code>.lrc</code> or <code>.txt</code>
      files into lyrics tags</li>
      <li>Remove existing lyrics files if a file is already tagged</li>
      <li>Supports multiple music libraries</li>
    </ul>
  </description>

  <categories>
    <category>Music</category>
    <category>AudioVideo</category>
  </categories>

  <keywords>
    <keyword>lyrics</keyword>
    <keyword>tag</keyword>
    <keyword>metadata</keyword>
    <keyword>sync</keyword>
    <keyword translate="no">LRC</keyword>
    <keyword translate="no">lrclib</keyword>
  </keywords>

  <recommends>
    <internet>always</internet>
    <control>pointing</control>
    <control>keyboard</control>
    <display_length compare="ge">800</display_length>
  </recommends>

  <branding>
    <color type="primary" scheme_preference="light">#f18b90</color>
    <color type="primary" scheme_preference="dark">#464b8d</color>
  </branding>

